{
  "manifest_version": 3,
  "name": "Order Manager Browser Integration",
  "version": "0.1.0",
  "description": "Integrate order data from store order pages into Order Manager.",
  "permissions": ["activeTab", "storage", "tabs", "cookies"],
  "host_permissions": [
    "https://ecom-api.costco.com/*",
    "https://api.usabuying.group/*",
    "https://api.prod.buyinggroup.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://localhost/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "action": {
  "default_popup": "popup/popup.html"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://www.costco.com/myaccount/*"],
      "js": ["stores/costco/bulk_capture.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.costco.com/myaccount/*"],
      "js": ["stores/costco/orders.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.walmart.com/*"],
      "js": ["stores/walmart/orders.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.walmart.com/*"],
      "js": ["stores/walmart/bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://*.usabuying.group/*"],
      "js": ["buying_groups/usabg/auth.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://*.usabuying.group/*"],
      "js": ["buying_groups/usabg/bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://buyinggroup.com/*",
        "https://*.buyinggroup.com/*"
      ],
      "js": ["buying_groups/bg/auth.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://buyinggroup.com/*",
        "https://*.buyinggroup.com/*"
      ],
      "js": ["buying_groups/bg/bridge.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["stores/costco/bulk_capture_injected.js"],
      "matches": ["https://www.costco.com/*"]
    }
  ]
}
