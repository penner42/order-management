{
  "manifest_version": 3,
  "name": "Order Manager Browser Integration",
  "version": "0.1.0",
  "description": "Integrate order data from store order pages into Order Manager. Supports Walmart (more stores coming).",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://api.usabuying.group/*"],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.walmart.com/orders*"],
      "js": ["stores/walmart/orders.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.costco.com/myaccount/*"],
      "js": ["stores/costco/orders.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.usabuying.group/*"],
      "js": ["buying_groups/usabg/auth.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://*.usabuying.group/*"],
      "js": ["buying_groups/usabg/bridge.js"],
      "run_at": "document_start"
    }
  ]
}
