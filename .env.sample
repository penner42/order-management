ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

### Browser extension (Firefox signing via Mozilla AMO)
WEB_EXT_API_KEY=
WEB_EXT_API_SECRET=

### TRACKING (package-tracking API)
UPS_CLIENT=your_ups_client_id
UPS_SECRET=your_ups_secret
# Optional: default is production. Sandbox: https://wwwcie.ups.com/security/v1/oauth/token
# UPS_OAUTH_URL=https://onlinetools.ups.com/security/v1/oauth/token